End Sub

Private Sub cboFilterStudyNumber_Change()
    FilterCombo Me.cboFilterStudyNumber, _
        "SELECT DISTINCT StudyNumber FROM tblStudies " & _
        "WHERE StudyNumber LIKE '*[TYPED]*' " & _
        "AND Len(Trim(Nz(StudyNumber,"""")))>0 ORDER BY StudyNumber"
