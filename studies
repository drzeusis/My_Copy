    FilterCombo Me.cboFilterSponsorProtocol, _
        "SELECT DISTINCT SponsorProtocol FROM tblStudies " & _
        "WHERE SponsorProtocol LIKE '*[TYPED]*' " & _
        "AND Len(Trim(Nz(SponsorProtocol,"""")))>0 ORDER BY SponsorProtocol"
End Sub

Private Sub cboFilterSponsorProtocol_AfterUpdate()
    ApplyFilters
End Sub

