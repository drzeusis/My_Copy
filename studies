Option Compare Database
Option Explicit

Private Const DEFAULT_CC  As String = "mtl-watson@crl.com"
Private isEditing         As Boolean
Private isNew             As Boolean
Private selectedStudyID   As Long

' =============================================
' FORM LOAD
' =============================================
Private Sub Form_Load()
    isEditing = False
    isNew = False
    selectedStudyID = 0
    SetFormState "locked"
End Sub

' =============================================
' SUBFORM ROW CLICKED — navigate detail
' =============================================
Public Sub StudySelected(studyID As Long)
    ' Block selection while editing
    If isEditing Or isNew Then
        MsgBox "Please save or cancel your current changes first.", _
               vbExclamation, "Unsaved Changes"
        Exit Sub
    End If

    selectedStudyID = studyID

    ' Navigate the bound form to this record
    Dim rs As DAO.Recordset
    Set rs = Me.RecordsetClone
    rs.FindFirst "StudyID = " & studyID
    If Not rs.NoMatch Then
        Me.Bookmark = rs.Bookmark
    End If
    rs.Close

    SetFormState "selected"
End Sub

' =============================================
' EDIT BUTTON
' =============================================
Private Sub cmdEdit_Click()
    isEditing = True
    SetFormState "editing"
End Sub

' =============================================
' NEW STUDY
' =============================================
Private Sub cmdNew_Click()
    If isEditing Or isNew Then
        Dim ans As Integer
        ans = MsgBox("You have unsaved changes. Save first?", _
                     vbYesNoCancel + vbQuestion, "Unsaved Changes")
        If ans = vbYes Then
            If Not ValidateForm() Then Exit Sub
            RunCommand acCmdSaveRecord
        ElseIf ans = vbCancel Then
            Exit Sub
        Else
            Me.Undo
        End If
    End If

    DoCmd.GoToRecord , , acNewRec
    Me.txtCC.Value = DEFAULT_CC
    selectedStudyID = 0
    isNew = True
    isEditing = False
    SetFormState "editing"
End Sub

' =============================================
' SAVE
' =============================================
Private Sub cmdSave_Click()
    If Not ValidateForm() Then Exit Sub

    RunCommand acCmdSaveRecord

    ' Refresh subform so new/edited study appears
    Me.subStudiesList.Form.Requery

    ' Refresh filter combos in case new protocols/numbers added
    RefreshFilterSources

    isEditing = False
    isNew = False

    If selectedStudyID = 0 Then
        selectedStudyID = Me.StudyID
    End If

    SetFormState "selected"
    MsgBox "Study saved successfully.", vbInformation, "Saved"
End Sub

' =============================================
' CANCEL
' =============================================
Private Sub cmdCancel_Click()
    If Me.Dirty Then
        If MsgBox("Discard changes?", vbYesNo + vbQuestion, "Cancel Edit") = vbNo Then
            Exit Sub
        End If
        Me.Undo
    End If

    isEditing = False

    If isNew Then
        isNew = False
        selectedStudyID = 0
        SetFormState "locked"
    Else
        SetFormState "selected"
    End If
End Sub

' =============================================
' DELETE
' =============================================
Private Sub cmdDelete_Click()
    If Me.NewRecord Then Exit Sub

    If DCount("*", "tblShipments", "StudyID=" & Me.StudyID) > 0 Then
        MsgBox "This study has existing shipments and cannot be deleted.", _
               vbExclamation, "Cannot Delete"
        Exit Sub
    End If

    If MsgBox("Delete this study permanently?", _
              vbYesNo + vbCritical, "Confirm Delete") = vbYes Then
        DoCmd.RunCommand acCmdDeleteRecord
        Me.subStudiesList.Form.Requery
        selectedStudyID = 0
        isEditing = False
        isNew = False
        SetFormState "locked"
    End If
End Sub

' =============================================
' CLOSE
' =============================================
Private Sub cmdClose_Click()
    If isEditing Or isNew Then
        Dim ans As Integer
        ans = MsgBox("You have unsaved changes. Save before closing?", _
                     vbYesNoCancel + vbQuestion, "Unsaved Changes")
        If ans = vbYes Then
            If Not ValidateForm() Then Exit Sub
            RunCommand acCmdSaveRecord
        ElseIf ans = vbCancel Then
            Exit Sub
        Else
            Me.Undo
        End If
    End If
    DoCmd.Close acForm, Me.Name
End Sub

' =============================================
' FILTER COMBOBOXES — type to filter list
' =============================================
Private Sub cboFilterClient_Change()
    FilterCombo Me.cboFilterClient, _
        "SELECT DISTINCT ClientName FROM tblClients " & _
        "WHERE ClientName LIKE '*[TYPED]*' ORDER BY ClientName"
End Sub

Private Sub cboFilterClient_AfterUpdate()
    ApplyFilters
End Sub

