        "SELECT DISTINCT SponsorProtocol AS Protocol FROM tblStudies " & _
        "WHERE SponsorProtocol LIKE '*[T]*' " & _
        "AND Len(Trim(Nz(SponsorProtocol,"""")))>0 " & _
        "UNION SELECT DISTINCT ClientProtocol FROM tblStudies " & _
        "WHERE ClientProtocol LIKE '*[T]*' " & _
        "AND Len(Trim(Nz(ClientProtocol,"""")))>0 " & _
        "ORDER BY Protocol"
End Sub

