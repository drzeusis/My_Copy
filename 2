Private Sub FilterCombo(cbo As ComboBox, sqlTemplate As String)
    Dim typed As String
    typed = cbo.Text
    If Len(typed) = 0 Then
        cbo.RowSource = Replace(sqlTemplate, " LIKE '*[T]*'", "")
    Else
        cbo.RowSource = Replace(sqlTemplate, "[T]", typed)
        cbo.Dropdown
    End If
End Sub

' =============================================
' APPLY ALL FILTERS TO SUBFORM
' =============================================
Private Sub ApplyFilters()
    Dim sql   As String
    Dim where As String

    sql = "SELECT sh.ShipmentID, sh.DeliveryDate, sh.SR, " & _
          "st.StudyNumber, st.SponsorProtocol, st.ClientProtocol, st.Matrix, " & _
          "sh.Samples, sh.Boxes, sh.Condition, sh.SplitType, sh.Waybill, " & _
          "t1.TechName AS Tech1, t2.TechName AS Tech2, " & _
          "f1.FreezerName AS TempFreezer, c.ClientName " & _
          "FROM (((((tblShipments sh " & _
          "INNER JOIN tblStudies st ON sh.StudyID = st.StudyID) " & _
          "LEFT JOIN tblTechs t1 ON st.Tech1ID = t1.TechID) " & _
          "LEFT JOIN tblTechs t2 ON st.Tech2ID = t2.TechID) " & _
          "LEFT JOIN tblFreezer f1 ON st.TempFreezerID = f1.FreezerID) " & _
          "LEFT JOIN tblClients c ON st.ClientID = c.ClientID)"

    ' SR filter
    If Not IsNull(Me.txtFilterSR) And Trim(Me.txtFilterSR & "") <> "" Then
        where = AddFilter(where, "sh.SR = '" & _
                Replace(Trim(Me.txtFilterSR.Value), "'", "''") & "'")
    End If

    ' Protocol filter — checks both sponsor and client protocol
    If Not IsNull(Me.cboFilterProtocol) And Trim(Me.cboFilterProtocol & "") <> "" Then
        Dim proto As String
        proto = Replace(Me.cboFilterProtocol.Value, "'", "''")
        where = AddFilter(where, "(st.SponsorProtocol = '" & proto & "' " & _
                "OR st.ClientProtocol = '" & proto & "')")
    End If

    ' Study Number filter
    If Not IsNull(Me.cboFilterStudyNumber) And Trim(Me.cboFilterStudyNumber & "") <> "" Then
        where = AddFilter(where, "st.StudyNumber = '" & _
                Replace(Me.cboFilterStudyNumber.Value, "'", "''") & "'")
    End If

    ' Client filter
    If Not IsNull(Me.cboFilterClient) And Trim(Me.cboFilterClient & "") <> "" Then
        where = AddFilter(where, "c.ClientName = '" & _
                Replace(Me.cboFilterClient.Value, "'", "''") & "'")
    End If

    ' Waybill filter
    If Not IsNull(Me.cboFilterWaybill) And Trim(Me.cboFilterWaybill & "") <> "" Then
        where = AddFilter(where, "sh.Waybill = '" & _
                Replace(Me.cboFilterWaybill.Value, "'", "''") & "'")
    End If

    ' Date range filter
    If IsDate(Me.txtDateFrom) Then
        where = AddFilter(where, "sh.DeliveryDate >= #" & _
                Format(CDate(Me.txtDateFrom.Value), "mm/dd/yyyy") & "#")
    End If
    If IsDate(Me.txtDateTo) Then
        where = AddFilter(where, "sh.DeliveryDate <= #" & _
                Format(CDate(Me.txtDateTo.Value), "mm/dd/yyyy") & "#")
    End If

    If where <> "" Then sql = sql & " WHERE " & where
    sql = sql & " ORDER BY sh.DeliveryDate DESC, sh.ShipmentID DESC"

    Me.subShipmentsList.Form.RecordSource = sql
End Sub

Private Function AddFilter(current As String, newCondition As String) As String
    If current = "" Then
        AddFilter = newCondition
    Else
        AddFilter = current & " AND " & newCondition
    End If
End Function

' =============================================
' CLEAR FILTERS
' =============================================
Private Sub cmdClearFilters_Click()
    Me.txtFilterSR.Value        = ""
    Me.cboFilterProtocol.Value  = Null
    Me.cboFilterStudyNumber.Value = Null
    Me.cboFilterClient.Value    = Null
    Me.cboFilterWaybill.Value   = Null
    Me.txtDateFrom.Value        = Date - 7
    Me.txtDateTo.Value          = Date

    ' Reset combobox row sources
    Me.cboFilterProtocol.RowSource = _
        "SELECT DISTINCT SponsorProtocol AS Protocol FROM tblStudies " & _
        "WHERE Len(Trim(Nz(SponsorProtocol,"""")))>0 " & _
        "UNION SELECT DISTINCT ClientProtocol FROM tblStudies " & _
        "WHERE Len(Trim(Nz(ClientProtocol,"""")))>0 ORDER BY Protocol"
    Me.cboFilterStudyNumber.RowSource = _
        "SELECT DISTINCT StudyNumber FROM tblStudies " & _
        "WHERE Len(Trim(Nz(StudyNumber,"""")))>0 ORDER BY StudyNumber"
    Me.cboFilterClient.RowSource = _
        "SELECT DISTINCT ClientName FROM tblClients ORDER BY ClientName"
    Me.cboFilterWaybill.RowSource = _
        "SELECT DISTINCT Waybill FROM tblShipments " & _
        "WHERE Len(Trim(Nz(Waybill,"""")))>0 ORDER BY Waybill"

    ApplyFilters
End Sub

